# ============================================
# CONFIGURACIÓN - Asistente IA Personal
# ============================================

# --------------------------------------------
# 1. ANTHROPIC (Claude API) - REQUERIDO
# --------------------------------------------
# Obtener en: https://console.anthropic.com/
# Formato: sk-ant-api03-xxxxx...
ANTHROPIC_API_KEY=sk-ant-xxx

# --------------------------------------------
# 2. TWILIO (WhatsApp) - REQUERIDO
# --------------------------------------------
# Crear cuenta en: https://www.twilio.com/try-twilio
# Account SID (comienza con AC...)
TWILIO_ACCOUNT_SID=ACxxx

# Auth Token de Twilio
TWILIO_AUTH_TOKEN=xxx

# Número de WhatsApp de Twilio
# Para desarrollo: whatsapp:+14155238886 (Twilio Sandbox)
# Para producción: whatsapp:+tu_numero_twilio
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --------------------------------------------
# 3. BASE DE DATOS
# --------------------------------------------
# DESARROLLO LOCAL (SQLite):
# DATABASE_URL=sqlite:///./goals.db

# DESARROLLO LOCAL (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/asistente_ia

# PRODUCCIÓN (Render PostgreSQL):
# Esta variable se auto-configura en Render cuando vinculas la base de datos
# Formato: postgresql://usuario:password@host.render.com/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/asistente_ia

# --------------------------------------------
# 4. CONFIGURACIÓN DE LA APP
# --------------------------------------------
# Genera una clave secreta aleatoria (mínimo 32 caracteres)
# Comando: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=tu-secret-key-aqui

# Ambiente de ejecución (development o production)
ENVIRONMENT=development

# Puerto (opcional - se auto-detecta en Render)
# PORT=8000

# --------------------------------------------
# NOTAS PARA DEPLOYMENT EN RENDER:
# --------------------------------------------
# 1. Crear PostgreSQL database en Render
# 2. DATABASE_URL se configurará automáticamente al vincular la BD
# 3. Todas las demás variables deben configurarse manualmente en Render Dashboard
# 4. Generar un nuevo SECRET_KEY para producción
# 5. Cambiar ENVIRONMENT=production
# 6. No es necesario configurar PORT (Render lo proporciona)
